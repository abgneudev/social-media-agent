# Kiloforge runtime secrets. Copy to /etc/kiloforge/kiloforge.env on the host,
# fill in real values, and chmod 600. NEVER commit the real file: .gitignore
# already excludes kiloforge.env.

# Bluesky handle (no leading @, no quotes).
# The agent strips '@', whitespace, and surrounding quotes defensively, but it
# is cleaner to set the bare handle here.
BLUESKY_HANDLE=yourhandle.bsky.social

# Bluesky APP PASSWORD (not your main password). Generate one at:
#   https://bsky.app/settings/app-passwords
# Use a dedicated app password for this agent so you can revoke it without
# affecting other sessions.
BLUESKY_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Groq API key for content generation. Create at:
#   https://console.groq.com/keys
GROQ_API_KEY=gsk_replace_me

# Gemini API key for versatile agent generation. Create at:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=gemini_replace_me

# Optional: override log level. Default INFO. Set to DEBUG for verbose
# diagnostics or WARNING to quiet the journal during stable operation.
# KILOFORGE_LOG_LEVEL=INFO

# Optional: Klipy app key for GIF attachment on original posts. Get one at:
#   https://klipy.com (developer console)
# When unset, posts go out text-only as before. GIF is always a bonus,
# never required: any resolve / fetch / upload failure degrades to text.
# KLIPY_APP_KEY=klipy_replace_me
